import std::time;
import std::io;
import std::string;
import std::math;
import std::json;
import std::http;

async fn add_two(x) {
    return x + 2;
}

async fn async_greet(name) {
    return "Hello, " + name + "!";
}

async fn test_async_functions() {
    let result = await add_two(5);
    let greeting = await async_greet("World");
    return [result, greeting];
}

async fn test_time_now() {
    let t1 = time.now();
    await time.sleep(50);
    let t2 = time.now();
    return t2 > t1;
}

async fn test_time_sleep() {
    let start = time.now();
    await time.sleep(20);
    let elapsed = time.now() - start;
    return elapsed >= 15 && elapsed <= 100;
}

async fn test_io_sync_write_read() {
    let test_file = "test_sync.txt";
    io.write_file(test_file, "Hello World!");
    let content = io.read_file(test_file);
    io.delete_file(test_file);
    return content == "Hello World!";
}

async fn test_io_async_write_read() {
    let test_file = "test_async.txt";
    await io.write_file_async(test_file, "Hello Async!");
    let content = await io.read_file_async(test_file);
    await io.delete_file_async(test_file);
    return content == "Hello Async!";
}

async fn test_io_append() {
    let test_file = "test_append.txt";
    io.write_file(test_file, "First");
    io.append_file(test_file, " Second");
    let content = io.read_file(test_file);
    io.delete_file(test_file);
    return content == "First Second";
}

async fn test_io_exists() {
    let test_file = "test_exists.txt";
    let before = io.exists(test_file);
    io.write_file(test_file, "test");
    let after = io.exists(test_file);
    io.delete_file(test_file);
    return before == false && after == true;
}

async fn test_io_is_file_is_dir() {
    let test_file = "test_isfile.txt";
    let test_dir = "test_dir_temp";
    
    io.write_file(test_file, "content");
    io.create_dir(test_dir);
    
    let file_check = io.is_file(test_file) == true && io.is_file(test_dir) == false;
    let dir_check = io.is_dir(test_dir) == true && io.is_dir(test_file) == false;
    
    io.delete_file(test_file);
    io.delete_dir(test_dir);
    
    return file_check && dir_check;
}

async fn test_io_list_dir() {
    let test_dir = "test_list_dir";
    io.create_dir(test_dir);
    io.write_file(test_dir + "/a.txt", "a");
    io.write_file(test_dir + "/b.txt", "b");
    
    let files = io.list_dir(test_dir);
    
    io.delete_file(test_dir + "/a.txt");
    io.delete_file(test_dir + "/b.txt");
    io.delete_dir(test_dir);
    
    return files.len() == 2;
}

async fn test_io_create_delete_dir() {
    let test_dir = "test_mkdir_temp";
    let before = io.exists(test_dir);
    io.create_dir(test_dir);
    let after_create = io.exists(test_dir);
    io.delete_dir(test_dir);
    let after_delete = io.exists(test_dir);
    
    return before == false && after_create == true && after_delete == false;
}

async fn test_string_join() {
    let arr = ["Hello", "World", "!"];
    let result = string.join(arr, " ");
    return result == "Hello World !";
}

async fn test_math_clamp() {
    let r1 = math.clamp(5, 0, 10) == 5;
    let r2 = math.clamp(-5, 0, 10) == 0;
    let r3 = math.clamp(15, 0, 10) == 10;
    return r1 && r2 && r3;
}

async fn test_math_random() {
    let r1 = math.random();
    let r2 = math.random(1, 10);
    let r3 = math.random(100, 200);
    let valid_range = r1 >= 0 && r1 <= 10 && r2 >= 1 && r2 <= 10 && r3 >= 100 && r3 <= 200;
    let not_all_same = !(r1 == r2 && r2 == r3);
    return valid_range && not_all_same;
}

async fn test_math_round() {
    return math.round(3.7) == 4.0;
}

async fn test_json_serialize() {
    let data = {"name": "Alice", "age": 30};
    let json_str = json.serialize(data);
    return json_str.starts_with("{") && json_str.ends_with("}");
}

async fn test_json_deserialize() {
    let json_str = "{\"name\": \"Bob\", \"age\": 25}";
    let data = json.deserialize(json_str);
    let name_val = data["name"];
    return name_val == "Bob";
}

async fn test_try_catch() {
    let result = try {
        throw "Test error";
        false
    } catch (e) {
        true
    };
    return result == true;
}

async fn test_http_get() {
    let response = await http.get("https://httpbin.org/get");
    return response["status"] == 200;
}

async fn test_http_post() {
    let response = await http.post("https://httpbin.org/post", "test data");
    return response["status"] == 200;
}

async fn test_http_put() {
    let response = await http.put("https://httpbin.org/put", "put data");
    return response["status"] == 200;
}

async fn test_http_delete() {
    let response = await http.delete("https://httpbin.org/delete");
    return response["status"] == 200;
}

async fn main() {
    println("=== Testing async/await ===");
    let async_result = await test_async_functions();
    println("  add_two(5) + async_greet: " + async_result.to_string());
    
    println("\n=== Testing std.time ===");
    println("  now(): " + (await test_time_now()).to_string());
    println("  sleep(20ms): " + (await test_time_sleep()).to_string());
    
    println("\n=== Testing std.io ===");
    println("  write_file/read_file: " + (await test_io_sync_write_read()).to_string());
    println("  write_file_async/read_file_async: " + (await test_io_async_write_read()).to_string());
    println("  append_file: " + (await test_io_append()).to_string());
    println("  exists: " + (await test_io_exists()).to_string());
    println("  is_file/is_dir: " + (await test_io_is_file_is_dir()).to_string());
    println("  list_dir: " + (await test_io_list_dir()).to_string());
    println("  create_dir/delete_dir: " + (await test_io_create_delete_dir()).to_string());
    
    println("\n=== Testing std.string ===");
    println("  join: " + (await test_string_join()).to_string());
    
    println("\n=== Testing std.math ===");
    println("  clamp: " + (await test_math_clamp()).to_string());
    println("  random: " + (await test_math_random()).to_string());
    println("  round: " + (await test_math_round()).to_string());
    
    println("\n=== Testing std.json ===");
    println("  serialize: " + (await test_json_serialize()).to_string());
    println("  deserialize: " + (await test_json_deserialize()).to_string());
    
    println("\n=== Testing try/catch ===");
    println("  throw/catch: " + (await test_try_catch()).to_string());
    
    println("\n=== Testing std.http ===");
    println("  http_get: " + (await test_http_get()).to_string());
    println("  http_post: " + (await test_http_post()).to_string());
    println("  http_put: " + (await test_http_put()).to_string());
    println("  http_delete: " + (await test_http_delete()).to_string());
    
    println("\n=== All tests completed! ===");
}

main();